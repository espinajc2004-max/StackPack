{
  "name": "stackpack-cli",
  "version": "0.3.4",
  "description": "Local-first, privacy-focused terminal integration builder for JavaScript and TypeScript projects. Official tooling first, presets stay on your device.",
  "type": "module",
  "license": "MIT",
  "author": "Jc Espina <espinajc2004@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espinajc2004-max/StackPack.git"
  },
  "homepage": "https://github.com/espinajc2004-max/StackPack#readme",
  "bugs": {
    "url": "https://github.com/espinajc2004-max/StackPack/issues"
  },
  "bin": {
    "stackpack": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "vite",
    "nextjs",
    "react",
    "integrations",
    "local-first"
  ],
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0",
    "execa": "^10.0.0",
    "fast-glob": "^3.3.3",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "semver": "^7.8.5",
    "validate-npm-package-name": "^7.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "@types/validate-npm-package-name": "^4.0.2",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.9",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
