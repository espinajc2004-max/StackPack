{
  "name": "stackpack",
  "version": "0.2.0",
  "description": "Local-first CLI for saving and installing reusable JS/TS development stacks",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "stackpack": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  },
  "private": true
}
